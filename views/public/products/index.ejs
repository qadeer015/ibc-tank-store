<!-- views/public/products/index.ejs -->
<div class="px-lg-5">

    <h2 class="mb-4">Products</h2>

    <div class="row">
        <!-- Filters Sidebar -->
        <aside class="col-md-3">
            <div class="card filter-card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Filter Products</h5>
                </div>
                <div class="card-body">
                    <form id="filterForm" action="/search" method="GET">
                        <!-- Search Query -->
                        <input type="hidden" name="q" value="<%= searchQuery %>">

                        <!-- Category Filter -->
                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <select name="category" class="form-select">
                                <option value="">All Categories</option>
                                <% categories.forEach(category=> { %>
                                    <option value="<%= category.id %>" <%=selectedCategory==category.id ? 'selected'
                                        : '' %>
                                        >
                                        <%= category.name %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>

                        <!-- Price Range Filter -->
                        <div class="mb-3">
                            <label class="form-label">Price Range</label>
                            <div class="row g-2">
                                <div class="col">
                                    <input type="number" name="minPrice" class="form-control" placeholder="Min"
                                        value="<%= minPrice %>">
                                </div>
                                <div class="col">
                                    <input type="number" name="maxPrice" class="form-control" placeholder="Max"
                                        value="<%= maxPrice %>">
                                </div>
                            </div>
                        </div>

                        <!-- Condition Filter -->
                        <div class="mb-3">
                            <label class="form-label">Condition</label>
                            <select name="condition" class="form-select">
                                <option value="">Any Condition</option>
                                <option value="new" <%=condition==='new' ? 'selected' : '' %>>New</option>
                                <option value="used" <%=condition==='used' ? 'selected' : '' %>>Used</option>
                                <option value="refurbished" <%=condition==='refurbished' ? 'selected' : '' %>
                                    >Refurbished
                                </option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
                    </form>
                </div>
            </div>
        </aside>
        <!-- Latest Products Grid -->
        <section class="col-md-9">
            <div class="row row-cols-1 row-cols-md-3 g-4">
                <% products.forEach(product=> { %>
                <div class="col">
                    <div class="card product-card h-100 overflow-hidden border-0 rounded-0">
                        <a class="text-decoration-none text-dark" href="/products/<%= product.id %>">
                            <img src="<%= product.image %>" loading="lazy" class="card-img-top product-img"
                                alt="<%= product.name %>">
                        </a>
                        <div class="card-body position-relative">
                            <a class="text-decoration-none text-dark" href="/products/<%= product.id %>">
                                <p class="card-title mb-0">
                                    <%= product.name %>
                                </p>
                            </a>
                            <a class="text-decoration-none text-dark" href="/products/<%= product.id %>">
                                <strong class="card-text">
                                    <%= settings.price_currency %>
                                        <%= product.price %>
                                </strong>
                            </a>
                            <div class="pop-up-footer bg-primary p-2 text-center">
                                <a href="https://wa.me/<%= settings.contact_number %>?text=<%= encodeURIComponent('Hi, I am interested in this product: ' + product.name) %>"
                                    class="whatsapp-btn text-white text-decoration-none fw-semibold" target="_blank"
                                    rel="noopener noreferrer">
                                    <i class="bi bi-whatsapp me-1"></i> Contact
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </section>
    </div>
</div>