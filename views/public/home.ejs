<section class="ibc-section" style="background:var(--ibc-gray-100)">
    <div class="ibc-container">
        <h2 class="ibc-section-title ibc-animate">What Our Customers Say</h2>
        <div class="ibc-accent-line"></div>
        <p class="ibc-section-subtitle ibc-animate">Real reviews from businesses and individuals who trust IBC Tank
            Store.</p>
        <div class="ibc-testimonial-slider" id="testimonialSlider">
            <div class="ibc-testimonial-track">
                <div class="ibc-testimonial-slide">
                    <div class="ibc-testimonial-card">
                        <div class="ibc-testimonial-stars">
                            <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                        </div>
                        <p class="ibc-testimonial-text">Excellent quality IBC tanks. We ordered 20 tanks for our agriculture farm and they delivered within 3 days to Multan. Very professional service!</p>
                        <div class="ibc-testimonial-author">
                            <div class="ibc-testimonial-avatar">AH</div>
                            <div>
                                <div class="ibc-testimonial-name">Ahmed Hassan</div>
                                <div class="ibc-testimonial-city">Multan, Punjab</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="ibc-testimonial-slide">
                    <div class="ibc-testimonial-card">
                        <div class="ibc-testimonial-stars">
                            <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                        </div>
                        <p class="ibc-testimonial-text">Best prices for bulk IBC tank orders in Pakistan. We've been buying from them for 2 years now. Chemical tanks are top quality and well-maintained.</p>
                        <div class="ibc-testimonial-author">
                            <div class="ibc-testimonial-avatar">FK</div>
                            <div>
                                <div class="ibc-testimonial-name">Faisal Khan</div>
                                <div class="ibc-testimonial-city">Lahore, Punjab</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="ibc-testimonial-slide">
                    <div class="ibc-testimonial-card">
                        <div class="ibc-testimonial-stars">
                            <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                        </div>
                        <p class="ibc-testimonial-text">I was looking for a food grade IBC tank for my juice business. They had exactly what I needed and delivered to Karachi within 4 days. Highly recommended!</p>
                        <div class="ibc-testimonial-author">
                            <div class="ibc-testimonial-avatar">SR</div>
                            <div>
                                <div class="ibc-testimonial-name">Sara Raza</div>
                                <div class="ibc-testimonial-city">Karachi, Sindh</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <button class="ibc-slider-btn ibc-slider-prev" onclick="ibcSlideTestimonial(-1)"><i class="bi bi-chevron-left"></i></button>
            <button class="ibc-slider-btn ibc-slider-next" onclick="ibcSlideTestimonial(1)"><i class="bi bi-chevron-right"></i></button>
            <div class="ibc-slider-dots" id="testimonialDots"></div>
        </div>
        <script>
        (function(){
            var slider = document.getElementById('testimonialSlider');
            if(!slider) return;
            var track = slider.querySelector('.ibc-testimonial-track');
            var slides = slider.querySelectorAll('.ibc-testimonial-slide');
            var dots = document.getElementById('testimonialDots');
            var current = 0;
            var total = slides.length;
            var autoInterval;

            // Create dots
            for(var i=0; i<total; i++){
                var dot = document.createElement('button');
                dot.className = 'ibc-slider-dot' + (i===0?' active':'');
                dot.setAttribute('aria-label','Testimonial '+(i+1));
                dot.onclick = (function(idx){return function(){goTo(idx)}})(i);
                dots.appendChild(dot);
            }

            function goTo(idx){
                slides[current].classList.remove('active');
                current = (idx+total)%total;
                track.style.transform = 'translateX(-'+(current*100)+'%)';
                slides[current].classList.add('active');
                var allDots = dots.querySelectorAll('.ibc-slider-dot');
                for(var d=0;d<allDots.length;d++) allDots[d].classList.toggle('active',d===current);
            }

            window.ibcSlideTestimonial = function(dir){
                clearInterval(autoInterval);
                goTo(current+dir);
                startAuto();
            };

            function startAuto(){
                autoInterval = setInterval(function(){goTo(current+1)},5000);
            }

            goTo(0);
            startAuto();
        })();
        </script>
    </div>
</section>

