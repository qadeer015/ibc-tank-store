<section class="ibc-cta-banner ibc-animate">
    <div class="ibc-container">
        <h2>Ready to Order IBC Tanks?</h2>
        <p>Get the best prices on bulk and retail IBC tanks. Talk to our expert team for personalized recommendations.
        </p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
            <a href="https://wa.me/<%= settings.contact_number %>?text=Hello%2C%20I%20am%20interested%20in%20your%20IBC%20tanks.%20Please%20share%20pricing%20and%20availability."
                class="ibc-btn ibc-btn-whatsapp ibc-btn-lg" target="_blank" rel="noopener noreferrer">
                <i class="bi bi-whatsapp"></i> WhatsApp Us Now
            </a>
            <a href="tel:+<%= settings.contact_number %>" class="ibc-btn ibc-btn-dark ibc-btn-lg">
                <i class="bi bi-telephone"></i> Call: <%= settings.contact_number %>
            </a>
        </div>
    </div>
</section>

<!-- ============================================================ -->
<!-- LEAD GENERATION / QUOTE FORM -->
<!-- ============================================================ -->
<section class="ibc-quote-section ibc-section" id="quote-form">
    <div class="ibc-container">
        <div style="display:grid;grid-template-columns:1fr;gap:40px;align-items:center" class="ibc-animate">
            <!-- Left side info -->
            <div>
                <h2 style="color:var(--ibc-white);font-size:28px;font-weight:800;margin-bottom:16px">Get a Free Quote
                </h2>
                <p style="color:rgba(255,255,255,.8);font-size:16px;line-height:1.7;margin-bottom:24px">
                    Fill out the form and our team will get back to you within 30 minutes with the best pricing for your
                    IBC tank requirements.
                </p>
                <div style="display:flex;flex-direction:column;gap:16px">
                    <div style="display:flex;align-items:center;gap:12px;color:rgba(255,255,255,.8)">
                        <i class="bi bi-check-circle-fill" style="color:var(--ibc-accent);font-size:20px"></i>
                        <span>Free consultation and quote</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:12px;color:rgba(255,255,255,.8)">
                        <i class="bi bi-check-circle-fill" style="color:var(--ibc-accent);font-size:20px"></i>
                        <span>No obligation — just expert advice</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:12px;color:rgba(255,255,255,.8)">
                        <i class="bi bi-check-circle-fill" style="color:var(--ibc-accent);font-size:20px"></i>
                        <span>Response within 30 minutes</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:12px;color:rgba(255,255,255,.8)">
                        <i class="bi bi-check-circle-fill" style="color:var(--ibc-accent);font-size:20px"></i>
                        <span>Bulk discounts available</span>
                    </div>
                </div>
            </div>
            <!-- Right side form -->
            <div>
                <div class="ibc-quote-form">
                    <h2>Request Free Quote</h2>
                    <p class="ibc-form-subtitle">Fill in your details and we'll contact you shortly.</p>
                    <form action="/contact/quote" method="POST">
                        <div class="ibc-quote-form-grid">
                            <div class="ibc-form-group">
                                <label for="quote-name">Your Name *</label>
                                <input type="text" id="quote-name" name="name" placeholder="Enter your full name"
                                    required>
                            </div>
                            <div class="ibc-form-group">
                                <label for="quote-phone">Phone Number *</label>
                                <input type="tel" id="quote-phone" name="phone" placeholder="03XX XXXXXXX" required>
                            </div>
                            <div class="ibc-form-group">
                                <label for="quote-city">City *</label>
                                <select id="quote-city" name="city" required>
                                    <option value="">Select your city</option>
                                    <option value="Lahore">Lahore</option>
                                    <option value="Karachi">Karachi</option>
                                    <option value="Islamabad">Islamabad</option>
                                    <option value="Faisalabad">Faisalabad</option>
                                    <option value="Multan">Multan</option>
                                    <option value="Peshawar">Peshawar</option>
                                    <option value="Gujranwala">Gujranwala</option>
                                    <option value="Sialkot">Sialkot</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                            <div class="ibc-form-group">
                                <label for="quote-product">Product Type *</label>
                                <select id="quote-product" name="product_type" required>
                                    <option value="">Select product type</option>
                                    <option value="Water IBC Tank">Water IBC Tank</option>
                                    <option value="Chemical IBC Tank">Chemical IBC Tank</option>
                                    <option value="Fertilizer IBC Tank">Fertilizer IBC Tank</option>
                                    <option value="Food Grade IBC Tank">Food Grade IBC Tank</option>
                                    <option value="Diesel Storage Tank">Diesel Storage Tank</option>
                                    <option value="Used IBC Tank">Used IBC Tank</option>
                                </select>
                            </div>
                            <div class="ibc-form-group">
                                <label for="quote-quantity">Quantity *</label>
                                <input type="number" id="quote-quantity" name="quantity" placeholder="How many tanks?"
                                    min="1" required>
                            </div>
                            <div class="ibc-form-group">
                                <label for="quote-usage">Intended Usage</label>
                                <input type="text" id="quote-usage" name="usage"
                                    placeholder="e.g., Water storage for farm">
                            </div>
                        </div>
                        <button type="submit" class="ibc-btn ibc-btn-primary ibc-btn-lg"
                            style="width:100%;justify-content:center;margin-top:8px">
                            <i class="bi bi-send"></i> Request Free Quote
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Schema.org Structured Data for Homepage -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "IBC Tank Store",
  "description": "Pakistan's trusted supplier of IBC tanks for water, chemical, fertilizer, and industrial storage.",
  "url": "https://ibctankstore.com",
  "telephone": "+<%= settings.contact_number %>",
  "email": "info@ibctankstore.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Lahore",
    "addressRegion": "Punjab",
    "addressCountry": "PK"
  },
  "areaServed": "PK",
  "priceRange": "PKR 8,000 - PKR 25,000",
  "openingHours": "Mo-Sa 09:00-18:00",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "500"
  }
}
</script>